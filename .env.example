# ──────────────────────────────────────────────────────────────
#  .env.example — Sao chép thành .env và điền giá trị thật
#  cp .env.example .env
#  File .env đã được loại khỏi git (.gitignore)
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=facerecog
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO (Object Storage) ──
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET_FACES=face-images
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_SECURE=false

# ── Qdrant (Vector DB) ──
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=face_embeddings

# ── JWT — BẮT BUỘC đổi trước khi deploy ──
# Tạo key ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── AI Model ──
MODEL_PATH=/app/models/best_model.pth
EMBEDDING_SIZE=512
AI_THRESHOLD=0.630
LIVENESS_ENABLED=true

# ── Backup định kỳ (Celery, 3h sáng mỗi ngày) ──
BACKUP_ENABLED=true
# Trong container (không cần đổi trừ khi mount khác)
BACKUP_DIR=/backups
# Thư mục trên máy Windows/Linux — backup thật sự nằm ở đây
# Windows: dùng slash hoặc backslash, vd. D:/Backups/facerecog
BACKUP_HOST_DIR=./backups
BACKUP_RETENTION_DAYS=7
# true = copy toàn bộ ảnh MinIO mỗi lần backup (rất nặng). false = chỉ DB + vector
BACKUP_INCLUDE_MINIO=false

# ── Google Drive (xem docs/BACKUP_GOOGLE_DRIVE.md) ──
GOOGLE_DRIVE_ENABLED=false
# oauth = Gmail cá nhân | service_account = Workspace Shared Drive
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_OAUTH_TOKEN=/secrets/gdrive-oauth-token.json
GOOGLE_DRIVE_CREDENTIALS=/secrets/gdrive-service-account.json

# ── App ──
DEBUG=false
